# Raqmi System Server
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/raqmi_system"
JWT_SECRET="REPLACE_WITH_LONG_RANDOM_VALUE"

# File storage: local | s3 | hybrid
FILE_STORAGE_DRIVER="local"
FILE_STORAGE_LOCAL_PATH="./storage"

# S3 or compatible cloud storage
S3_ENDPOINT="http://localhost:9000"
S3_REGION="REGION"
S3_BUCKET="raqmi-system"
S3_ACCESS_KEY_ID="ACCESS_KEY"
S3_SECRET_ACCESS_KEY="SECRET_KEY"

# License mode: online | offline | hybrid
LICENSE_MODE="offline"
LICENSE_FILE_PATH="./license.license"
LICENSE_MANAGER_URL="https://licenses.example.com"
LICENSE_OFFLINE_GRACE_DAYS="30"
