# Raqmi System — environnement local complet
PORT=3000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_VALUE

# PostgreSQL (docker compose)
DATABASE_URL=postgresql://raqmi:raqmi_password@localhost:5432/raqmi_system

# Mettre DEMO_MODE=true pour forcer le mode demo sans base
# DEMO_MODE=false

# Stockage fichiers: local | s3 | hybrid
FILE_STORAGE_DRIVER=local
FILE_STORAGE_LOCAL_PATH=./storage

# MinIO (S3 compatible — docker compose)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=raqmi-system
S3_ACCESS_KEY_ID=raqmi
S3_SECRET_ACCESS_KEY=raqmi_password

# Licence
LICENSE_MODE=offline
LICENSE_FILE_PATH=./license.license
LICENSE_MANAGER_URL=http://localhost:3001
LICENSE_OFFLINE_GRACE_DAYS=30
