{
  "name": "raqmi-system-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "dev:desktop": "electron .",
    "dev:desktop:all": "concurrently -k \"vite --host 0.0.0.0 --port 5173\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "test": "echo no-client-tests-yet",
    "lint": "echo no-client-lint-yet"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.1.0",
    "typescript": "^5.7.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.62.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "concurrently": "^9.2.1",
    "electron": "^36.7.4",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "dz.raqmi.system.client",
    "productName": "Raqmi System",
    "directories": {
      "output": "installers"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Raqmi System"
    }
  }
}
