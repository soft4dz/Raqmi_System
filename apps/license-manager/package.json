{
  "name": "raqmi-license-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5174",
    "dev:desktop": "electron .",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview --port 4174",
    "typecheck": "tsc --noEmit",
    "test": "echo no-license-manager-tests-yet",
    "lint": "echo no-license-manager-lint-yet"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.1.0",
    "typescript": "^5.7.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "electron": "^36.7.4",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "dz.raqmi.license.manager",
    "productName": "Raqmi License Manager",
    "directories": {
      "output": "installers"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Raqmi License Manager"
    }
  }
}
