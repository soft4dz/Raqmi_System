generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum LicenseKind {
  TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

enum LicenseMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum LicenseStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

enum ActivationStatus {
  ACTIVE
  BLOCKED
  REVOKED
}

enum StorageDriver {
  LOCAL
  S3
  HYBRID
}

model Tenant {
  id          String       @id @default(uuid())
  code        String       @unique
  name        String
  legalName   String?
  email       String?
  phone       String?
  address     String?
  status      TenantStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  sites       Site[]
  users       User[]
  licenses    License[]
  files       FileObject[]

  @@map("tenants")
}

model Site {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  name      String
  type      String   @default("site")
  city      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@map("sites")
}

model ModuleDefinition {
  id          String   @id @default(uuid())
  code        String   @unique
  label       String
  family      String
  commercial  Boolean  @default(true)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  licenseModules LicenseModule[]

  @@map("module_definitions")
}

model License {
  id                  String        @id @default(uuid())
  tenantId            String
  kind                LicenseKind
  mode                LicenseMode
  status              LicenseStatus @default(DRAFT)
  startsAt            DateTime
  expiresAt           DateTime
  maxUsers            Int
  maxSites            Int
  maxStorageGb        Int
  offlineGraceDays    Int           @default(30)
  serverFingerprint   String?
  signedPayload       String?
  signature           String?
  lastOnlineCheckAt   DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  tenant              Tenant        @relation(fields: [tenantId], references: [id])
  modules             LicenseModule[]
  activations         LicenseActivation[]

  @@index([tenantId, status])
  @@map("licenses")
}

model LicenseModule {
  id        String   @id @default(uuid())
  licenseId String
  moduleId  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  license   License          @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  module    ModuleDefinition @relation(fields: [moduleId], references: [id])

  @@unique([licenseId, moduleId])
  @@map("license_modules")
}

model LicenseActivation {
  id                 String           @id @default(uuid())
  licenseId          String
  serverFingerprint  String
  serverLabel        String?
  ipAddress          String?
  hostname           String?
  status             ActivationStatus @default(ACTIVE)
  activatedAt        DateTime         @default(now())
  lastSeenAt         DateTime?
  revokedAt          DateTime?

  license            License          @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, serverFingerprint])
  @@map("license_activations")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String
  roleCode     String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@map("users")
}

model FileObject {
  id              String        @id @default(uuid())
  tenantId        String
  siteId          String?
  storageDriver   StorageDriver @default(LOCAL)
  bucket          String?
  path            String
  originalName    String
  mimeType        String?
  sizeBytes       BigInt
  checksumSha256  String?
  moduleCode      String?
  entityType      String?
  entityId        String?
  uploadedBy      String?
  uploadedAt      DateTime      @default(now())
  cloudSyncedAt   DateTime?

  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId, moduleCode, entityType, entityId])
  @@map("file_objects")
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String?
  userId      String?
  action      String
  moduleCode  String?
  entityType  String?
  entityId    String?
  description String
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
