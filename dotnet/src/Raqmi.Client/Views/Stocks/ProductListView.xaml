<UserControl x:Class="Raqmi.Client.Views.Stocks.ProductListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="0,0,8,8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,8,0">
          <TextBlock Text="Code" Style="{StaticResource LabelText}"/>
          <TextBox x:Name="CodeBox"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,8,0">
          <TextBlock Text="Nom" Style="{StaticResource LabelText}"/>
          <TextBox x:Name="NameBox"/>
        </StackPanel>
        <Button Grid.Column="2" Content="Ajouter" Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom" Click="OnAdd"/>
      </Grid>
    </Border>
    <DataGrid x:Name="Grid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120"/>
        <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="*"/>
        <DataGridTextColumn Header="Unité" Binding="{Binding Unit}" Width="80"/>
        <DataGridTextColumn Header="Stock min" Binding="{Binding MinStockLevel}" Width="100"/>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
