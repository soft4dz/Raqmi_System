<UserControl x:Class="Raqmi.Client.Views.Stocks.StockMovementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="0,0,8,8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,8,0">
          <TextBlock Text="Produit ID" Style="{StaticResource LabelText}"/>
          <TextBox x:Name="ProductIdBox"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,8,0">
          <TextBlock Text="Type (in/out)" Style="{StaticResource LabelText}"/>
          <TextBox x:Name="TypeBox" Text="in"/>
        </StackPanel>
        <StackPanel Grid.Column="2" Margin="0,0,8,0">
          <TextBlock Text="Quantité" Style="{StaticResource LabelText}"/>
          <TextBox x:Name="QtyBox" Text="1"/>
        </StackPanel>
        <Button Grid.Column="3" Content="Enregistrer" Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom" Click="OnAdd"/>
      </Grid>
    </Border>
    <DataGrid x:Name="Grid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Produit" Binding="{Binding ProductId}" Width="*"/>
        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80"/>
        <DataGridTextColumn Header="Qté" Binding="{Binding Quantity}" Width="80"/>
        <DataGridTextColumn Header="Date" Binding="{Binding MovementDate}" Width="120"/>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
