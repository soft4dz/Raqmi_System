<UserControl x:Class="Raqmi.Client.Views.Hr.EmployeeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="0,0,8,8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,8,0">
          <TextBlock Text="Matricule" Style="{StaticResource LabelText}"/>
          <TextBox x:Name="MatriculeBox"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,8,0">
          <TextBlock Text="Prénom" Style="{StaticResource LabelText}"/>
          <TextBox x:Name="FirstNameBox"/>
        </StackPanel>
        <StackPanel Grid.Column="2" Margin="0,0,8,0">
          <TextBlock Text="Nom" Style="{StaticResource LabelText}"/>
          <TextBox x:Name="LastNameBox"/>
        </StackPanel>
        <Button Grid.Column="3" Content="Ajouter" Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom" Click="OnAdd"/>
      </Grid>
    </Border>
    <DataGrid x:Name="Grid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Matricule" Binding="{Binding Matricule}" Width="100"/>
        <DataGridTextColumn Header="Prénom" Binding="{Binding FirstName}" Width="*"/>
        <DataGridTextColumn Header="Nom" Binding="{Binding LastName}" Width="*"/>
        <DataGridTextColumn Header="Département" Binding="{Binding Department}" Width="120"/>
        <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="80"/>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
