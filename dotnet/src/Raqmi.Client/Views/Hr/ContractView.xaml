<UserControl x:Class="Raqmi.Client.Views.Hr.ContractView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="0,0,8,8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
      <StackPanel>
        <TextBlock Text="Employé" Style="{StaticResource LabelText}"/>
        <ComboBox x:Name="EmployeeBox" DisplayMemberPath="Label" Margin="0,4,0,0"/>
      </StackPanel>
    </Border>
    <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,8,0">
          <TextBlock Text="Type (cdi/cdd/stage)" Style="{StaticResource LabelText}"/>
          <TextBox x:Name="TypeBox" Text="cdi"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,8,0">
          <TextBlock Text="Salaire base" Style="{StaticResource LabelText}"/>
          <TextBox x:Name="SalaryBox" Text="3000"/>
        </StackPanel>
        <Button Grid.Column="2" Content="Ajouter contrat" Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom" Click="OnAdd"/>
      </Grid>
    </Border>
    <DataGrid x:Name="Grid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Type" Binding="{Binding ContractType}" Width="100"/>
        <DataGridTextColumn Header="Début" Binding="{Binding StartDate}" Width="*"/>
        <DataGridTextColumn Header="Salaire" Binding="{Binding BaseSalary}" Width="120"/>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
