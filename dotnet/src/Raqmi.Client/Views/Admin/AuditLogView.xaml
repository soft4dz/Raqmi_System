<UserControl x:Class="Raqmi.Client.Views.Admin.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="0,0,8,8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
      <StackPanel>
        <TextBlock Text="Filtres" Style="{StaticResource LabelText}"/>
        <Grid Margin="0,8,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock Text="Action" Style="{StaticResource LabelText}"/>
            <ComboBox x:Name="ActionBox" Margin="0,4,0,0"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Margin="0,0,8,0">
            <TextBlock Text="Module" Style="{StaticResource LabelText}"/>
            <TextBox x:Name="ModuleBox"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Margin="0,0,8,0">
            <TextBlock Text="Recherche" Style="{StaticResource LabelText}"/>
            <TextBox x:Name="SearchBox"/>
          </StackPanel>
          <Button Grid.Column="3" Content="Filtrer" Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom" Click="OnFilter"/>
        </Grid>
        <TextBlock x:Name="ErrorText" Foreground="#FCA5A5" Margin="0,8,0,0" Visibility="Collapsed"/>
      </StackPanel>
    </Border>
    <DataGrid x:Name="Grid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Date" Binding="{Binding CreatedAtLabel}" Width="160"/>
        <DataGridTextColumn Header="Utilisateur" Binding="{Binding UserName}" Width="*"/>
        <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="100"/>
        <DataGridTextColumn Header="Module" Binding="{Binding ModuleCode}" Width="120"/>
        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
