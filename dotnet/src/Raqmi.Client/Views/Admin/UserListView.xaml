<UserControl x:Class="Raqmi.Client.Views.Admin.UserListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="0,0,8,8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Email" Style="{StaticResource LabelText}"/>
                <TextBox x:Name="EmailBox"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="0,0,8,0">
                <TextBlock Text="Nom complet" Style="{StaticResource LabelText}"/>
                <TextBox x:Name="FullNameBox"/>
              </StackPanel>
              <StackPanel Grid.Column="2" Margin="0,0,8,0">
                <TextBlock Text="Rôle" Style="{StaticResource LabelText}"/>
                <ComboBox x:Name="RoleBox" Margin="0,4,0,0"/>
              </StackPanel>
              <Button Grid.Column="3" Content="Ajouter" Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom" Click="OnAdd"/>
            </Grid>
            <TextBlock Text="Sites affectés (un ou plusieurs)" Style="{StaticResource LabelText}" Margin="0,12,0,6"/>
            <ItemsControl x:Name="SitesPicker"/>
            <TextBlock x:Name="ErrorText" Foreground="#FCA5A5" Margin="0,8,0,0" Visibility="Collapsed"/>
          </StackPanel>
        </Border>
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12" Visibility="Collapsed" x:Name="EditSitesPanel">
          <StackPanel>
            <TextBlock x:Name="EditSitesTitle" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
            <ItemsControl x:Name="EditSitesPicker"/>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
              <Button Content="Enregistrer sites" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="OnSaveSites"/>
              <Button Content="Annuler" Style="{StaticResource GhostButton}" Click="OnCancelEditSites"/>
            </StackPanel>
          </StackPanel>
        </Border>
        <DataGrid x:Name="Grid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
            <DataGridTextColumn Header="Nom" Binding="{Binding FullName}" Width="*"/>
            <DataGridTextColumn Header="Rôle" Binding="{Binding RoleCode}" Width="80"/>
            <DataGridTextColumn Header="Sites" Binding="{Binding SitesLabel}" Width="*"/>
            <DataGridCheckBoxColumn Header="Actif" Binding="{Binding Active}" Width="60"/>
            <DataGridTemplateColumn Header="Action" Width="140">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <Button Content="Sites" Style="{StaticResource GhostButton}" Margin="0,0,4,0" Click="OnEditSites" Tag="{Binding Id}"/>
                    <Button Content="Activer/Désactiver" Style="{StaticResource GhostButton}" Click="OnToggleActive" Tag="{Binding Id}"/>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
  </Grid>
</UserControl>
