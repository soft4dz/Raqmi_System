<UserControl x:Class="Raqmi.Client.Views.Ged.DocumentLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="0,0,8,8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Border Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
      <StackPanel Orientation="Horizontal">
        <Button Content="Importer fichier" Style="{StaticResource PrimaryButton}" Click="OnUpload"/>
        <Button Content="Actualiser" Style="{StaticResource GhostButton}" Margin="8,0,0,0" Click="OnRefresh"/>
      </StackPanel>
    </Border>
    <DataGrid x:Name="Grid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Nom" Binding="{Binding OriginalName}" Width="*"/>
        <DataGridTextColumn Header="Type" Binding="{Binding MimeType}" Width="120"/>
        <DataGridTextColumn Header="Taille" Binding="{Binding SizeBytes}" Width="80"/>
        <DataGridTextColumn Header="Module" Binding="{Binding ModuleCode}" Width="100"/>
        <DataGridTemplateColumn Header="Action" Width="100">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <Button Content="Suppr." Style="{StaticResource GhostButton}" Click="OnDelete" Tag="{Binding Id}"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
