<UserControl x:Class="Raqmi.Client.Views.Shell.MainShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="260"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
      <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Margin="8,8,8,16">
          <TextBlock Text="Raqmi System" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
          <TextBlock x:Name="TenantText" Style="{StaticResource SubtitleText}" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="NavPanel"/>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Border Style="{StaticResource CardBorder}" Padding="16,14" Margin="16,16,16,8">
        <Grid>
          <TextBlock x:Name="ScreenTitle" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Border Background="{StaticResource Panel2Brush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="999" Padding="12,6" Margin="0,0,10,0">
              <TextBlock x:Name="UserChip" Foreground="{StaticResource TextBrush}" FontSize="13"/>
            </Border>
            <Button x:Name="LogoutButton" Style="{StaticResource GhostButton}" Click="OnLogout"/>
          </StackPanel>
        </Grid>
      </Border>
      <ContentControl x:Name="ContentHost" Grid.Row="1" Margin="16,0,16,16"/>
    </Grid>
  </Grid>
</UserControl>
