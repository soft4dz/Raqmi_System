<Window x:Class="Raqmi.LicenseManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Raqmi License Manager" Height="860" Width="1280" MinHeight="720" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="{StaticResource AppFont}">

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- En-tête -->
    <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="16,14" Margin="0,0,0,16">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Style="{StaticResource BrandMark}" Width="40" Height="40" CornerRadius="12">
            <TextBlock Text="R" FontSize="18" FontWeight="Bold" Foreground="#BFDBFE"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="Raqmi License Manager" Style="{StaticResource TitleText}" FontSize="20"/>
            <TextBlock Text="Éditeur de licences signées pour clients Raqmi" Style="{StaticResource SubtitleText}"/>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Liste clients -->
      <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="Clients" Style="{StaticResource TitleText}" FontSize="18" Margin="0,0,0,12"/>
          <ListBox x:Name="TenantsList" Height="520" DisplayMemberPath="Name" SelectionChanged="OnTenantChanged"/>
          <Button Content="+ Nouveau client" Style="{StaticResource PrimaryButton}" Margin="0,14,0,0" Click="OnAddTenant"/>
        </StackPanel>
      </Border>

      <!-- Détail licence -->
      <Border Grid.Column="1" Style="{StaticResource CardBorder}">
        <StackPanel>
          <TextBlock x:Name="TitleText" Style="{StaticResource TitleText}"/>
          <TextBlock Text="Configurez le pack, les dates et exportez le fichier .license signé."
                     Style="{StaticResource SubtitleText}" Margin="0,6,0,20"/>

          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
              <TextBlock Text="Pack" Style="{StaticResource LabelText}"/>
              <ComboBox x:Name="PackBox" SelectionChanged="OnPackChanged"/>
              <TextBlock Text="Statut" Style="{StaticResource LabelText}"/>
              <ComboBox x:Name="StatusBox"/>
              <TextBlock Text="Empreinte serveur (optionnel)" Style="{StaticResource LabelText}"/>
              <TextBox x:Name="FingerprintBox"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
              <TextBlock Text="Début" Style="{StaticResource LabelText}"/>
              <DatePicker x:Name="StartDate"/>
              <TextBlock Text="Expiration" Style="{StaticResource LabelText}"/>
              <DatePicker x:Name="EndDate"/>
            </StackPanel>
          </Grid>

          <WrapPanel Margin="0,8,0,0">
            <Button Content="Activer" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="OnActivate"/>
            <Button Content="Suspendre" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="OnSuspend"/>
            <Button Content="Prolonger 1 an" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="OnExtend"/>
            <Button Content="Exporter .license" Style="{StaticResource PrimaryButton}" Margin="0,0,0,8" Click="OnExport"/>
          </WrapPanel>

          <Border x:Name="StatusPanel" Background="{StaticResource Panel2Brush}" BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,12,0,0" Visibility="Collapsed">
            <TextBlock x:Name="StatusMessage" TextWrapping="Wrap" Foreground="{StaticResource TextBrush}"/>
          </Border>

          <TextBlock Text="Modules autorisés" FontWeight="SemiBold" FontSize="16"
                     Foreground="{StaticResource TextBrush}" Margin="0,20,0,10"/>
          <ScrollViewer Height="240" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ModulesList"/>
          </ScrollViewer>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
